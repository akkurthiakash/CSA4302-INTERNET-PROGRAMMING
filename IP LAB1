  // Login Validation

function validateLogin() {

let email = document.getElementById("email").value;

let password = document.getElementById("password").value;

if(email==""){

alert("Please enter Email");

return false;

}

if(password==""){

alert("Please enter Password");

return false;

}

alert("Login Successful");

return true;

}

// Registration Validation

function validateRegister(){

let name=document.getElementById("name").value;

let email=document.getElementById("regEmail").value;

let password=document.getElementById("regPassword").value;

let confirm=document.getElementById("confirmPassword").value;

let department=document.getElementById("department").value;

let year=document.getElementById("year").value;

let semester=document.getElementById("semester").value;

if(name==""){

alert("Enter Name");

return false;

}

if(email==""){

alert("Enter Email");

return false;

}

if(password==""){

alert("Enter Password");

return false;

}

if(password.length<6){

alert("Password should contain minimum 6 characters");

return false;

}

if(password!=confirm){

alert("Password does not match");

return false;

}

if(department==""){

alert("Enter Department");

return false;

}

if(year=="Select Year"){

alert("Select Year");

return false;

}

if(semester=="Select Semester"){

alert("Select Semester");

return false;

}

alert("Registration Successful");

return true;

}
function issueBook(){

let sid=document.getElementById("sid").value;
let sname=document.getElementById("sname").value;
let bid=document.getElementById("bid").value;
let bname=document.getElementById("bname").value;
let issue=document.getElementById("issuedate").value;
let ret=document.getElementById("returndate").value;

if(sid==""){
alert("Enter Student ID");
return false;
}

if(sname==""){
alert("Enter Student Name");
return false;
}

if(bid==""){
alert("Enter Book ID");
return false;
}

if(bname==""){
alert("Enter Book Name");
return false;
}

if(issue==""){
alert("Select Issue Date");
return false;
}

if(ret==""){
alert("Select Return Date");
return false;
}

alert("Book Issued Successfully");

return true;

}
function calculateFine(){

let due=new Date(document.getElementById("dueDate").value);

let actual=new Date(document.getElementById("actualDate").value);

if(document.getElementById("dueDate").value=="" ||
document.getElementById("actualDate").value==""){

alert("Select both dates");

return;

}

let diff=actual-due;

let days=Math.ceil(diff/(1000*60*60*24));

let fine=0;

if(days>0){

fine=days*10;

}

document.getElementById("fine").value=fine;

}

function returnBook(){

if(document.getElementById("rsid").value==""){

alert("Enter Student ID");

return false;

}

if(document.getElementById("rsname").value==""){

alert("Enter Student Name");

return false;

}

if(document.getElementById("rbid").value==""){

alert("Enter Book ID");

return false;

}

if(document.getElementById("rbname").value==""){

alert("Enter Book Name");

return false;

}

if(document.getElementById("status").value=="Select Status"){

alert("Select Return Status");

return false;

}

alert("Book Returned Successfully");

return true;

}
function uploadMaterial(){

let subject=document.getElementById("subject").value;
let year=document.getElementById("year").value;
let semester=document.getElementById("semester").value;
let file=document.getElementById("pdfFile").value;

if(subject==""){
alert("Enter Subject Name");
return false;
}

if(year=="Select Year"){
alert("Select Year");
return false;
}

if(semester=="Select Semester"){
alert("Select Semester");
return false;
}

if(file==""){
alert("Choose PDF File");
return false;
}

alert("Material Uploaded Successfully");

return true;

}
function updateProfile(){

let name=document.getElementById("studentName").value;
let email=document.getElementById("studentEmail").value;

if(name==""){

alert("Enter Student Name");

return false;

}

if(email==""){

alert("Enter Email");

return false;

}

alert("Profile Updated Successfully");

