HTML:
<!DOCTYPE html>
<html>
<head>
    <title>Bus Ticket Booking System</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h1>🚌 Bus Ticket Booking System</h1>
</header>

<div class="container">

<h2>Book Ticket</h2>

<input type="text" id="name" placeholder="Passenger Name">

<input type="text" id="route" placeholder="Route">

<input type="date" id="date">

<select id="bus">
    <option value="">Select Bus Type</option>
    <option>Volvo</option>
    <option>Sleeper</option>
    <option>AC Coach</option>
</select>

<input type="number" id="seat" placeholder="Seat Number">

<button onclick="bookTicket()">Book Ticket</button>

<hr>

<h2>Cancel Ticket</h2>

<input type="text" id="booking" placeholder="Booking ID">

<button onclick="cancelTicket()">Cancel Ticket</button>

<hr>

<h2>Comments</h2>

<textarea id="comment" placeholder="Enter your comment"></textarea>

<button onclick="addComment()">Submit</button>

</div>

<script src="script.js"></script>

</body>

CSS:
body{
    font-family:Arial;
    background:#f2f2f2;
    margin:0;
}

header{
    background:#004080;
    color:white;
    text-align:center;
    padding:15px;
}

.container{
    width:400px;
    margin:30px auto;
    background:white;
    padding:20px;
    border-radius:8px;
    box-shadow:0 0 10px gray;
}

input,select,textarea{
    width:100%;
    padding:10px;
    margin:8px 0;
}

button{
    width:100%;
    padding:10px;
    background:#004080;
    color:white;
    border:none;
    cursor:pointer;
}

button:hover{
    background:#0066cc;
}

JS:
function bookTicket(){

let name=document.getElementById("name").value;
let route=document.getElementById("route").value;
let date=document.getElementById("date").value;
let bus=document.getElementById("bus").value;
let seat=document.getElementById("seat").value;

if(name=="" || route=="" || date=="" || bus=="" || seat==""){
    alert("Please fill all booking details");
    return;
}

alert("Ticket Booked Successfully");
}

function cancelTicket(){

let booking=document.getElementById("booking").value;

if(booking==""){
    alert("Enter Booking ID");
    return;
}

alert("Ticket Cancelled Successfully");
}

function addComment(){

let comment=document.getElementById("comment").value;

if(comment==""){
    alert("Enter your comment");
    return;
}

alert("Comment Submitted Successfully");
}
</html>
