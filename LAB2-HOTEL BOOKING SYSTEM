<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hotel Room Booking System</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<header>
<h1>Hotel Room Booking System</h1>

<nav>
<a href="#home">Home</a>
<a href="#rooms">Rooms</a>
<a href="#booking">Book Room</a>
<a href="#history">Booking History</a>
<a href="#contact">Contact</a>
</nav>
</header>

<!-- Home -->

<section id="home">

<h2>Welcome to Dream Hotel</h2>

<p>
Book luxury rooms online at affordable prices.
Enjoy comfortable stay with excellent facilities.
</p>

<img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=900"
width="100%" height="350">

</section>

<!-- Rooms -->

<section id="rooms">

<h2>Available Rooms</h2>

<div class="card">

<h3>Standard Room</h3>

<p>Price : ₹1500 / Night</p>

<ul>

<li>Free WiFi</li>

<li>AC</li>

<li>TV</li>

</ul>

<button onclick="selectRoom('Standard Room',1500)">
Book
</button>

</div>

<div class="card">

<h3>Deluxe Room</h3>

<p>Price : ₹2500 / Night</p>

<ul>

<li>Free Breakfast</li>

<li>AC</li>

<li>TV</li>

<li>WiFi</li>

</ul>

<button onclick="selectRoom('Deluxe Room',2500)">
Book
</button>

</div>

<div class="card">

<h3>Family Room</h3>

<p>Price : ₹3500 / Night</p>

<ul>

<li>4 Members</li>

<li>WiFi</li>

<li>TV</li>

<li>Breakfast</li>

</ul>

<button onclick="selectRoom('Family Room',3500)">
Book
</button>

</div>

<div class="card">

<h3>Suite Room</h3>

<p>Price : ₹5000 / Night</p>

<ul>

<li>Luxury Stay</li>

<li>Mini Bar</li>

<li>Swimming Pool</li>

<li>King Bed</li>

</ul>

<button onclick="selectRoom('Suite Room',5000)">
Book
</button>

</div>

</section>

<!-- Booking -->

<section id="booking">

<h2>Book Your Room</h2>

<form id="bookingForm">

<label>Name</label>

<input
type="text"
id="name"
required>

<label>Email</label>

<input
type="email"
id="email"
required>

<label>Phone</label>

<input
type="text"
id="phone"
required>

<label>Room Type</label>

<input
type="text"
id="room"
readonly>

<label>Price</label>

<input
type="text"
id="price"
readonly>

<label>Check In</label>

<input
type="date"
id="checkin"
required>

<label>Check Out</label>

<input
type="date"
id="checkout"
required>

<label>Guests</label>

<input
type="number"
id="guests"
min="1"
required>

<button type="submit">
Confirm Booking
</button>

</form>

</section>

<!-- Booking History -->

<section id="history">

<h2>Your Booking History</h2>

<table>

<thead>

<tr>

<th>Name</th>

<th>Room</th>

<th>Check In</th>

<th>Check Out</th>

<th>Guests</th>

</tr>

</thead>

<tbody id="historyTable">

</tbody>

</table>

</section>

<!-- Contact -->

<section id="contact">

<h2>Contact Us</h2>

<p>Email : hotel@gmail.com</p>

<p>Phone : +91 9876543210</p>

<p>Address : Chennai, India</p>

</section>

<footer>

<p>
© 2026 Hotel Booking System
</p>

</footer>

<script src="script.js"></script>

</body>
</html>
